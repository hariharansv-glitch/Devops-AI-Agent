# =============================================================================
# AI DevOps Assistant - Environment Configuration
# =============================================================================
# Copy this file to `.env` and fill in the values for your environment.
# NEVER commit a real `.env` file to source control.
# =============================================================================


# -----------------------------------------------------------------------------
# LLM provider - pick Gemini OR Groq (or any other LiteLLM-supported provider).
#
# The MODEL_NAME prefix selects the provider:
#   * "gemini-..."   -> uses GOOGLE_API_KEY (or Vertex AI)
#   * "groq/..."     -> uses GROQ_API_KEY via LiteLLM
#   * "openai/..."   -> uses OPENAI_API_KEY via LiteLLM (add the key manually)
#   * "anthropic/..."-> uses ANTHROPIC_API_KEY via LiteLLM
# -----------------------------------------------------------------------------

# --- Gemini via Google AI Studio ---
# Get a key at https://aistudio.google.com/app/apikey.
# Required only if MODEL_NAME starts with "gemini".
GOOGLE_API_KEY=

# Set to TRUE to route Gemini through Vertex AI instead of AI Studio.
# When TRUE you must also set GOOGLE_CLOUD_PROJECT and GOOGLE_CLOUD_LOCATION,
# and be authenticated (`gcloud auth application-default login`).
GOOGLE_GENAI_USE_VERTEXAI=FALSE
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1

# --- Groq via LiteLLM ---
# Get a key at https://console.groq.com/keys (starts with gsk_...).
# Free tier is ~14,400 requests/day per model - much higher than Gemini.
# Required only if MODEL_NAME starts with "groq/".
GROQ_API_KEY=

# Which model the ADK LlmAgent should use. Examples:
#   gemini-2.5-flash                 (Google, needs GOOGLE_API_KEY)
#   gemini-2.5-flash-lite            (Google, cheaper/faster, needs GOOGLE_API_KEY)
#   groq/llama-3.3-70b-versatile     (Groq, best tool use, needs GROQ_API_KEY)
#   groq/llama-3.1-8b-instant        (Groq, fastest, needs GROQ_API_KEY)
MODEL_NAME=groq/llama-3.3-70b-versatile


# -----------------------------------------------------------------------------
# Target Linux VM (accessed over SSH)
# -----------------------------------------------------------------------------
# The assistant is CLOUD-AGNOSTIC. Any Linux VM reachable over SSH works:
#   * Oracle Cloud Infrastructure (OCI) - default user is `opc` on Oracle
#     Linux images, `ubuntu` on Ubuntu images. Use the private key OCI gave
#     you when you created the instance.
#   * Oracle VirtualBox / VMware / Hyper-V - use 127.0.0.1 and the forwarded
#     port (e.g. 2222). Password auth is fine for local dev.
#   * AWS EC2 - default user is `ec2-user`, `ubuntu`, or `admin` depending
#     on the AMI. Use the .pem file that AWS gave you.
#   * DigitalOcean / Hetzner / Linode - typically `root` with a private key.
#   * Raspberry Pi / self-hosted - whatever user + auth you configured.
#
VM_HOST=your.vm.host.or.ip
VM_PORT=22
VM_USER=ubuntu

# Provide EITHER a password OR a path to a private key (key wins if both set).
# On Windows the path can be a Windows path, e.g. C:\Users\me\.ssh\id_ed25519
VM_PASSWORD=
VM_PRIVATE_KEY=
# Optional passphrase for encrypted private keys.
VM_PRIVATE_KEY_PASSPHRASE=

# SSH client timeouts (seconds).
SSH_CONNECT_TIMEOUT=15
SSH_COMMAND_TIMEOUT=60

# Auto-accept unknown host keys. Set to FALSE and pre-populate known_hosts in
# production.
SSH_AUTO_ADD_HOST_KEYS=TRUE


# -----------------------------------------------------------------------------
# Application / API
# -----------------------------------------------------------------------------
APP_NAME=ai-devops-assistant
APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000

# Comma-separated list of origins allowed to hit the API. Use "*" for dev.
CORS_ORIGINS=*


# -----------------------------------------------------------------------------
# Safety
# -----------------------------------------------------------------------------
# READ_ONLY_MODE=TRUE prevents ANY destructive tool from running, even with
# explicit user confirmation. Use for demos, evaluations, and shared VMs.
READ_ONLY_MODE=TRUE

# Extra commands (regex, one per line, semicolon-separated) that the SSH tool
# should refuse to execute even when explicitly requested. The defaults are
# already applied in code.
SSH_EXTRA_DENYLIST=


# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_JSON=FALSE
