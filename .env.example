# =============================================================================
# AI DevOps Assistant - Environment Configuration
# =============================================================================
# Copy this file to `.env` and fill in the values for your environment.
# NEVER commit a real `.env` file to source control.
# =============================================================================


# -----------------------------------------------------------------------------
# Google Gemini / ADK
# -----------------------------------------------------------------------------
# Google AI Studio API key (https://aistudio.google.com/app/apikey).
# Required when GOOGLE_GENAI_USE_VERTEXAI=FALSE.
GOOGLE_API_KEY=your-google-ai-studio-api-key

# Set to TRUE to route Gemini calls through Vertex AI instead of AI Studio.
# When TRUE you must also set GOOGLE_CLOUD_PROJECT and GOOGLE_CLOUD_LOCATION,
# and be authenticated (`gcloud auth application-default login`).
GOOGLE_GENAI_USE_VERTEXAI=FALSE
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1

# Gemini model used by the ADK LlmAgent. Any Gemini 2.5 SKU works.
MODEL_NAME=gemini-2.5-flash


# -----------------------------------------------------------------------------
# Target Linux VM (accessed over SSH)
# -----------------------------------------------------------------------------
VM_HOST=your.vm.host.or.ip
VM_PORT=22
VM_USER=ubuntu

# Provide EITHER a password OR a path to a private key (key wins if both set).
VM_PASSWORD=
VM_PRIVATE_KEY=
# Optional passphrase for encrypted private keys.
VM_PRIVATE_KEY_PASSPHRASE=

# SSH client timeouts (seconds).
SSH_CONNECT_TIMEOUT=15
SSH_COMMAND_TIMEOUT=60

# Auto-accept unknown host keys. Set to FALSE and pre-populate known_hosts in
# production.
SSH_AUTO_ADD_HOST_KEYS=TRUE


# -----------------------------------------------------------------------------
# Application / API
# -----------------------------------------------------------------------------
APP_NAME=ai-devops-assistant
APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000

# Comma-separated list of origins allowed to hit the API. Use "*" for dev.
CORS_ORIGINS=*


# -----------------------------------------------------------------------------
# Safety
# -----------------------------------------------------------------------------
# READ_ONLY_MODE=TRUE prevents ANY destructive tool from running, even with
# explicit user confirmation. Use for demos, evaluations, and shared VMs.
READ_ONLY_MODE=TRUE

# Extra commands (regex, one per line, semicolon-separated) that the SSH tool
# should refuse to execute even when explicitly requested. The defaults are
# already applied in code.
SSH_EXTRA_DENYLIST=


# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_JSON=FALSE
